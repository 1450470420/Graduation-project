/* 校园跑腿学生端 - 全局样式 */

/* 颜色变量（暖红系主题） */
page {
  --primary: #D32F2F;
  --primary-light: #EF5350;
  --primary-dark: #B71C1C;
  --bg: #f5f5f5;
  --white: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border: #eeeeee;
  --success: #4CAF50;
  --warning: #FF9800;
  --danger: #F44336;
  
  background-color: var(--bg);
  color: var(--text-primary);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  font-size: 28rpx;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  background: var(--bg);
}

/* 卡片样式 */
.card {
  background: var(--white);
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 按鈕样式 */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  font-size: 30rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  letter-spacing: 2rpx;
  box-sizing: border-box;
}
/* 微信小程序 <button> 自带的 ::after 伪元素边框导致按鈕外部出现多余线框，全局清除 */
button::after { border: none; }
/* 清除微信 button 的内置内边距 + 居中 */
button { text-align: center !important; padding: 0 !important; }
button::after { border: none !important; }

.btn-primary:active {
  background: var(--primary-dark);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* 状态标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
}

.tag-warning { background: #FFF3E0; color: #FF9800; }
.tag-success { background: #E8F5E9; color: #4CAF50; }
.tag-danger { background: #FFEBEE; color: #F44336; }
.tag-primary { background: #FFEBEE; color: #D32F2F; }
.tag-info { background: #F5F5F5; color: #9E9E9E; }

/* 文字辅助 */
.text-primary { color: var(--primary); }
.text-secondary { color: var(--text-secondary); }
.text-hint { color: var(--text-hint); }
.text-bold { font-weight: 700; }
.text-center { text-align: center; }

/* flex */
.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-column { display: flex; flex-direction: column; }

/* 空状态 */
.empty-state {
  padding: 100rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: var(--text-hint);
}

.empty-state .empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
