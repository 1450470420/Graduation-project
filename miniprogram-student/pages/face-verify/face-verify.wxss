.verify-page{display:flex;flex-direction:column;height:100vh;background:#000}
.tip-bar{padding:16rpx 24rpx;background:rgba(0,0,0,.8);text-align:center}
.tip-text{font-size:28rpx;color:#FFD54F}
.camera-area{flex:1;position:relative;overflow:hidden}
.verify-camera{width:100%;height:100%}
.camera-devtools{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48rpx;gap:28rpx}
.devtools-text{font-size:26rpx;color:rgba(255,255,255,.85);line-height:1.7;text-align:center}
.btn-debug{min-width:320rpx;height:88rpx;line-height:88rpx;border-radius:44rpx;background:linear-gradient(135deg,#D32F2F,#E57373);color:#fff;font-size:30rpx;border:none}
.btn-debug[disabled]{opacity:.6}
.oval-mask{position:absolute;top:50%;left:50%;width:400rpx;height:520rpx;transform:translate(-50%,-50%);border:4rpx dashed rgba(255,255,255,.75);border-radius:50%;pointer-events:none;box-shadow:0 0 0 2000rpx rgba(0,0,0,.4)}
.scan-line{position:absolute;left:50%;width:360rpx;height:4rpx;transform:translateX(-50%);background:linear-gradient(90deg,transparent,#4CAF50,transparent);animation:scan 2s ease-in-out infinite}
@keyframes scan{0%{top:25%}50%{top:65%}100%{top:25%}}
.bottom-bar{padding:24rpx 40rpx 60rpx;background:rgba(0,0,0,.85);display:flex;flex-direction:column;align-items:center;gap:16rpx}
.order-info{display:flex;align-items:center;gap:12rpx;margin-bottom:8rpx}
.order-label{font-size:24rpx;color:#999}
.order-no{font-size:24rpx;color:#FFD54F}
.btn-snap{background:transparent!important;border:none;padding:0;width:140rpx;height:140rpx;display:flex;align-items:center;justify-content:center}
.snap-ring{width:130rpx;height:130rpx;border:6rpx solid #fff;border-radius:50%;display:flex;align-items:center;justify-content:center}
.snap-inner{width:100rpx;height:100rpx;border-radius:50%;background:#D32F2F;transition:all .2s}
.snap-loading{background:#999;animation:pulse 1s infinite}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(.85)}}
.snap-hint{font-size:24rpx;color:rgba(255,255,255,.7)}
