.page { background: #f5f5f5; min-height: 100vh; }
.score-card { background: #fff; margin: 24rpx; border-radius: 20rpx; padding: 40rpx 32rpx; display: flex; align-items: center; gap: 40rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); }
.score-circle { width: 140rpx; height: 140rpx; border-radius: 50%; background: linear-gradient(135deg, #D32F2F, #B71C1C); display: flex; flex-direction: column; align-items: center; justify-content: center; flex-shrink: 0; }
.score-num { font-size: 56rpx; font-weight: 800; color: #fff; line-height: 1; }
.score-unit { font-size: 22rpx; color: rgba(255,255,255,0.8); }
.score-info { flex: 1; }
.score-level { font-size: 32rpx; font-weight: 700; display: block; margin-bottom: 12rpx; }
.lv-a { color: #27AE60; }
.lv-b { color: #F39C12; }
.lv-c { color: #E67E22; }
.lv-d { color: #E74C3C; }
.score-tip { font-size: 24rpx; color: #999; }
.rules-card { background: #fff; margin: 0 24rpx 20rpx; border-radius: 12rpx; padding: 28rpx 32rpx; }
.rules-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.rule-item { display: flex; align-items: center; gap: 20rpx; padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; font-size: 26rpx; color: #555; }
.rule-item:last-child { border-bottom: none; }
.rule-icon { font-size: 28rpx; font-weight: 700; width: 60rpx; text-align: center; }
.green { color: #27AE60; }
.red { color: #E74C3C; }
.section-title { font-size: 28rpx; font-weight: 600; color: #333; padding: 16rpx 32rpx; }
.loading, .empty { text-align: center; padding: 80rpx 0; color: #999; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.empty-icon { font-size: 60rpx; }
.record-item { background: #fff; margin: 0 24rpx 16rpx; border-radius: 12rpx; padding: 28rpx 32rpx; display: flex; justify-content: space-between; align-items: center; }
.record-left { flex: 1; }
.record-reason { font-size: 28rpx; color: #333; display: block; margin-bottom: 8rpx; }
.record-time { font-size: 24rpx; color: #999; }
.record-score { font-size: 32rpx; font-weight: 700; }
.income { color: #27AE60; }
.expense { color: #E74C3C; }
