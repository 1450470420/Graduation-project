.container{padding:20rpx}
.card{background:#fff;border-radius:16rpx;padding:32rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06)}
.title{font-size:32rpx;font-weight:700;color:#333;text-align:center;margin-bottom:30rpx}
.stars{display:flex;justify-content:center;gap:20rpx;margin-bottom:16rpx}
.star{font-size:70rpx;color:#ddd}
.star.active{color:#FF9800}
.rating-text{text-align:center;font-size:26rpx;color:#FF9800;margin-bottom:24rpx}
.textarea{border:2rpx solid #eee;border-radius:12rpx;padding:20rpx;font-size:28rpx;min-height:160rpx;width:100%;box-sizing:border-box;margin-bottom:24rpx}
.submit-btn{background:#D32F2F;color:#fff;border-radius:50rpx;height:90rpx;line-height:90rpx;font-size:30rpx;text-align:center;}
