.msg-item{display:flex;align-items:flex-start;gap:20rpx;padding:24rpx 30rpx;background:#fff;border-bottom:1rpx solid #f5f5f5;position:relative}
.msg-item.unread{background:#FFF8F8}
.msg-icon{font-size:50rpx;flex-shrink:0}
.msg-content{flex:1}
.msg-title{font-size:28rpx;font-weight:600;color:#333;margin-bottom:6rpx}
.msg-body{font-size:24rpx;color:#666;margin-bottom:8rpx}
.msg-time{font-size:22rpx;color:#999}
.unread-dot{width:16rpx;height:16rpx;background:#D32F2F;border-radius:50%;position:absolute;top:24rpx;right:24rpx}
.empty-state{text-align:center;padding:100rpx;color:#999}.empty-icon{font-size:100rpx;display:block;margin-bottom:20rpx}
