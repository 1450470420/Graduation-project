.page{padding:24rpx;background:#f5f5f5;min-height:100vh}
.face-header{margin-bottom:32rpx}
.face-title{font-size:40rpx;font-weight:700;color:#333;display:block;margin-bottom:12rpx}
.face-desc{font-size:26rpx;color:#999;display:block;line-height:1.6}
.face-card{background:#fff;border-radius:20rpx;padding:40rpx;margin-bottom:24rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.06)}
.face-placeholder{display:flex;flex-direction:column;align-items:center;padding:40rpx 0}
.face-icon{font-size:120rpx;margin-bottom:20rpx}
.face-hint{font-size:28rpx;color:#999}
.btn-register{background:linear-gradient(135deg,#D32F2F,#E57373);color:#fff;border-radius:50rpx;height:96rpx;line-height:96rpx;font-size:32rpx;margin-top:32rpx;text-align:center;border:none}
.btn-register[disabled]{opacity:.6}
.tips-card{margin-top:32rpx;padding:24rpx;background:#FFF8E1;border-radius:12rpx}
.tips-title{font-size:26rpx;font-weight:600;color:#F57F17;display:block;margin-bottom:12rpx}
.tip-item{font-size:24rpx;color:#795548;display:block;line-height:1.8}
.face-registered{display:flex;align-items:center;gap:32rpx;margin-bottom:32rpx}
.face-photo-wrap{position:relative;flex-shrink:0}
.face-photo{width:160rpx;height:160rpx;border-radius:50%;border:4rpx solid #4CAF50}
.face-badge{position:absolute;bottom:-4rpx;left:50%;transform:translateX(-50%);background:#4CAF50;color:#fff;font-size:20rpx;padding:4rpx 16rpx;border-radius:20rpx;white-space:nowrap}
.face-status-info{flex:1}
.status-text{font-size:30rpx;font-weight:600;color:#333;display:block;margin-bottom:8rpx}
.status-sub{font-size:24rpx;color:#999;display:block}
.btn-reregister{background:#fff;color:#D32F2F;border:2rpx solid #D32F2F;border-radius:50rpx;height:88rpx;line-height:88rpx;font-size:28rpx;text-align:center}
.notice-card{background:#E3F2FD;border-radius:16rpx;padding:24rpx;margin-top:8rpx}
.notice-title{font-size:26rpx;font-weight:600;color:#1565C0;display:block;margin-bottom:10rpx}
.notice-text{font-size:24rpx;color:#37474F;display:block;line-height:1.7}

/* 相机采集区域 */
.camera-card{background:#000;border-radius:20rpx;overflow:hidden;margin-bottom:24rpx}
.camera-tip-bar{background:rgba(0,0,0,.7);padding:16rpx 24rpx;text-align:center}
.camera-tip{font-size:26rpx;color:#FFD54F}
.camera-wrap{position:relative;width:100%;height:680rpx}
.face-camera{width:100%;height:100%}
.face-oval{position:absolute;top:50%;left:50%;width:380rpx;height:480rpx;transform:translate(-50%,-50%);border:4rpx dashed rgba(255,255,255,.7);border-radius:50%;pointer-events:none;box-shadow:0 0 0 2000rpx rgba(0,0,0,.35)}
.camera-btns{display:flex;gap:24rpx;padding:24rpx;background:rgba(0,0,0,.8)}
.btn-cancel-cam{flex:1;background:rgba(255,255,255,.15);color:#fff;border-radius:50rpx;height:88rpx;line-height:88rpx;font-size:28rpx;text-align:center;border:none}
.btn-capture{flex:2;background:linear-gradient(135deg,#D32F2F,#E57373);color:#fff;border-radius:50rpx;height:88rpx;line-height:88rpx;font-size:30rpx;text-align:center;border:none;font-weight:600}
.btn-capture[disabled]{opacity:.6}
