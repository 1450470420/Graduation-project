<view class="reg-page">
  <view class="reg-header">
    <text class="logo">🏃</text>
    <text class="title">学生注册</text>
  </view>
  <view class="card">
    <view class="form-item"><text class="label">用户名</text><input class="input" value="{{username}}" bindinput="onInput" data-field="username" placeholder="请设置用户名"/></view>
    <view class="form-item"><text class="label">手机号</text><input class="input" value="{{phone}}" bindinput="onInput" data-field="phone" type="number" placeholder="请输入手机号"/></view>
    <view class="form-item"><text class="label">密码</text><input class="input" value="{{password}}" bindinput="onInput" data-field="password" password placeholder="请设置密码（至少6位）"/></view>
    <view class="form-item"><text class="label">确认密码</text><input class="input" value="{{confirmPwd}}" bindinput="onInput" data-field="confirmPwd" password placeholder="请再次输入密码"/></view>
    <button class="btn-primary" bindtap="handleRegister" disabled="{{loading}}">{{loading?'注册中...':'立即注册'}}</button>
    <view class="back-login" bindtap="goLogin">已有账号，去登录</view>
  </view>
</view>
