.reg-page{min-height:100vh;background:linear-gradient(160deg,#B71C1C 0%,#D32F2F 40%,#f5f5f5 100%);display:flex;flex-direction:column;align-items:center;padding-top:80rpx}
.reg-header{text-align:center;color:#fff;margin-bottom:40rpx}.logo{font-size:80rpx;display:block}.title{font-size:44rpx;font-weight:700;display:block;margin-top:12rpx}
.card{width:680rpx}.form-item{margin-bottom:24rpx}.label{display:block;font-size:26rpx;color:#666;margin-bottom:10rpx}
.input{border:2rpx solid #eee;border-radius:12rpx;padding:18rpx 24rpx;font-size:28rpx;background:#fafafa}
.btn-primary{background:#D32F2F;color:#fff;border-radius:50rpx;height:90rpx;line-height:90rpx;font-size:30rpx;letter-spacing:2rpx;margin-top:12rpx;text-align:center;}
.back-login{text-align:center;margin-top:20rpx;color:#D32F2F;font-size:26rpx}
