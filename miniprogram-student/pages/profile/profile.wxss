.profile-header{background:linear-gradient(135deg,#D32F2F,#EF5350);padding:40rpx 30rpx;display:flex;align-items:center;gap:24rpx;color:#fff}
.avatar-wrap{position:relative;width:100rpx;height:100rpx;flex-shrink:0}
.avatar{width:100rpx;height:100rpx;border-radius:50%;border:4rpx solid rgba(255,255,255,.5)}
.avatar-edit-mask{position:absolute;bottom:0;left:0;right:0;height:38rpx;background:rgba(0,0,0,.4);border-radius:0 0 50rpx 50rpx;display:flex;align-items:center;justify-content:center}
.avatar-edit-icon{font-size:20rpx;color:#fff}
.name{font-size:34rpx;font-weight:700;display:block}.phone,.rep{font-size:24rpx;opacity:.85;display:block;margin-top:6rpx}
.certified{background:rgba(255,255,255,.2);padding:6rpx 16rpx;border-radius:30rpx;font-size:22rpx;white-space:nowrap}
.menu-section{margin:20rpx}
.menu-item{display:flex;align-items:center;gap:16rpx;padding:24rpx 0;border-bottom:1rpx solid #f5f5f5}
.menu-icon{font-size:40rpx}.menu-text{flex:1;font-size:30rpx;color:#333}
.balance{color:#D32F2F;font-weight:700;font-size:30rpx}
.arrow{color:#ccc;font-size:28rpx}
.balance-val{color:#D32F2F;font-weight:700;font-size:30rpx;margin-right:8rpx}
.face-status{font-size:24rpx;padding:4rpx 16rpx;border-radius:20rpx;margin-right:8rpx}
.face-ok{background:#E8F5E9;color:#2E7D32}
.face-no{background:#FFF3E0;color:#E65100}
.logout-btn{background:#fff;color:#D32F2F;border:2rpx solid #D32F2F;border-radius:50rpx;margin:30rpx 40rpx;height:90rpx;line-height:90rpx;font-size:30rpx;text-align:center;}
/* 编辑弹窗 */
.modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:100}
.edit-modal{position:fixed;bottom:0;left:0;right:0;background:#fff;border-radius:32rpx 32rpx 0 0;padding:40rpx 32rpx;z-index:101;box-shadow:0 -4rpx 30rpx rgba(0,0,0,.1)}
.modal-title{font-size:34rpx;font-weight:700;color:#333;text-align:center;margin-bottom:32rpx}
.form-item{display:flex;align-items:center;padding:20rpx 0;border-bottom:1rpx solid #f5f5f5}
.form-label{width:140rpx;font-size:28rpx;color:#666;flex-shrink:0}
.form-input{flex:1;font-size:28rpx;color:#333;padding:0 12rpx}
.modal-btns{display:flex;gap:24rpx;margin-top:32rpx}
.btn-cancel{flex:1;background:#f5f5f5;color:#666;border-radius:50rpx;height:88rpx;line-height:88rpx;font-size:30rpx;border:none;text-align:center;}
.btn-confirm{flex:1;background:#D32F2F;color:#fff;border-radius:50rpx;height:88rpx;line-height:88rpx;font-size:30rpx;border:none;text-align:center;}
