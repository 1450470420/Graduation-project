<view class="page">
  <!-- 用户头部信息 -->
  <view class="profile-header" wx:if="{{userInfo}}">
    <!-- 头像可点击更换 -->
    <view class="avatar-wrap" bindtap="changeAvatar">
      <image class="avatar" src="{{userInfo.avatar||'/assets/default-avatar.png'}}" mode="aspectFill"/>
      <view class="avatar-edit-mask"><text class="avatar-edit-icon">📷</text></view>
    </view>
    <view class="user-info">
      <text class="name">{{userInfo.realName||userInfo.username}}</text>
      <text class="phone">📱 {{userInfo.phone}}</text>
      <text class="rep">🌟 信誉分：{{userInfo.reputation}}分</text>
    </view>
    <view class="certified" wx:if="{{userInfo.isCertified}}">&#x2705; 已认证</view>
  </view>

  <!-- 快捷入口 -->
  <view class="menu-section card">
    <view class="menu-item" bindtap="openEdit">
      <text class="menu-icon">✏️</text><text class="menu-text">编辑资料</text><text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="openChangePwd">
      <text class="menu-icon">🔒</text><text class="menu-text">修改密码</text><text class="arrow">></text>
    </view>
    <view class="menu-item" wx:if="{{!userInfo.isCertified}}" bindtap="openCertify">
      <text class="menu-icon">🆔</text><text class="menu-text">实名认证</text><text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goBalance">
      <text class="menu-icon">💰</text>
      <text class="menu-text">账户余额</text>
      <text class="balance-val">¥{{userInfo.balance}}</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goReputation">
      <text class="menu-icon">⭐</text><text class="menu-text">信誉分记录</text><text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goFace">
      <text class="menu-icon">🧑</text><text class="menu-text">人脸识别管理</text>
      <text class="face-status {{hasFace?'face-ok':'face-no'}}">{{hasFace?'已注册':'未注册'}}</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goAddress">
      <text class="menu-icon">📍</text><text class="menu-text">常用地址</text><text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goAnnouncement">
      <text class="menu-icon">📢</text><text class="menu-text">平台公告</text><text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goTicket">
      <text class="menu-icon">🎫</text><text class="menu-text">客服工单</text><text class="arrow">></text>
    </view>
  </view>

  <button class="logout-btn" bindtap="logout">退出登录</button>

  <!-- 修改密码弹窗 -->
  <view class="modal-mask" wx:if="{{showChangePwd}}" bindtap="closeChangePwd"></view>
  <view class="edit-modal" wx:if="{{showChangePwd}}">
    <view class="modal-title">🔒 修改密码</view>
    <view class="form-item"><text class="form-label">旧密码</text><input class="form-input" password value="{{pwdForm.oldPwd}}" bindinput="onInput" data-field="pwdForm.oldPwd" placeholder="输入旧密码"/></view>
    <view class="form-item"><text class="form-label">新密码</text><input class="form-input" password value="{{pwdForm.newPwd}}" bindinput="onInput" data-field="pwdForm.newPwd" placeholder="新密码（至少6位）"/></view>
    <view class="form-item"><text class="form-label">确认</text><input class="form-input" password value="{{pwdForm.confirmPwd}}" bindinput="onInput" data-field="pwdForm.confirmPwd" placeholder="再次输入新密码"/></view>
    <view class="modal-btns">
      <button class="btn-cancel" bindtap="closeChangePwd">取消</button>
      <button class="btn-confirm" bindtap="saveChangePwd">确认修改</button>
    </view>
  </view>

  <!-- 实名认证弹窗 -->
  <view class="modal-mask" wx:if="{{showCertify}}" bindtap="closeCertify"></view>
  <view class="edit-modal" wx:if="{{showCertify}}">
    <view class="modal-title">🆔 实名认证</view>
    <view class="form-item"><text class="form-label">真实姓名</text><input class="form-input" value="{{certifyForm.realName}}" bindinput="onInput" data-field="certifyForm.realName" placeholder="输入真实姓名"/></view>
    <view class="form-item"><text class="form-label">学号</text><input class="form-input" value="{{certifyForm.studentId}}" bindinput="onInput" data-field="certifyForm.studentId" placeholder="输入学号"/></view>
    <view class="modal-btns">
      <button class="btn-cancel" bindtap="closeCertify">取消</button>
      <button class="btn-confirm" bindtap="saveCertify">提交认证</button>
    </view>
  </view>

  <!-- 编辑资料弹窗 -->
  <view class="modal-mask" wx:if="{{showEdit}}" bindtap="closeEdit"></view>
  <view class="edit-modal" wx:if="{{showEdit}}">
    <view class="modal-title">编辑个人资料</view>
    <view class="form-item">
      <text class="form-label">姓名</text>
      <input class="form-input" value="{{editForm.realName}}" bindinput="onInput" data-field="editForm.realName" placeholder="请输入真实姓名"/>
    </view>
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" value="{{editForm.phone}}" bindinput="onInput" data-field="editForm.phone" placeholder="请输入手机号"/>
    </view>
    <view class="form-item">
      <text class="form-label">学号</text>
      <input class="form-input" value="{{editForm.studentId}}" bindinput="onInput" data-field="editForm.studentId" placeholder="请输入学号"/>
    </view>
    <view class="form-item">
      <text class="form-label">宿舍地址</text>
      <input class="form-input" value="{{editForm.dormAddress}}" bindinput="onInput" data-field="editForm.dormAddress" placeholder="如：1号楼301"/>
    </view>
    <view class="modal-btns">
      <button class="btn-cancel" bindtap="closeEdit">取消</button>
      <button class="btn-confirm" bindtap="saveEdit">保存</button>
    </view>
  </view>
</view>

