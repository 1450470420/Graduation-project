<view class="page">
  <!-- 顶部欢迎横幅 -->
  <view class="hero">
    <view class="hero-left">
      <text class="welcome">你好，{{userInfo.realName||userInfo.username}} 👋</text>
      <text class="sub">有{{pendingCount}}个进行中的订单</text>
    </view>
    <image class="hero-avatar" src="{{userInfo.avatar||'/assets/default-avatar.png'}}" mode="aspectFill"/>
  </view>

  <!-- 快送入口 -->
  <view class="quick-entry card">
    <view class="entry-item" bindtap="goPublish" data-type="代取快递">
      <text class="entry-icon">📦</text><text class="entry-text">代取快递</text>
    </view>
    <view class="entry-item" bindtap="goPublish" data-type="代买">
      <text class="entry-icon">🛒</text><text class="entry-text">代买服务</text>
    </view>
    <view class="entry-item" bindtap="goPublish" data-type="代送">
      <text class="entry-icon">🚀</text><text class="entry-text">代送服务</text>
    </view>
    <view class="entry-item" bindtap="goOrders">
      <text class="entry-icon">📋</text><text class="entry-text">我的订单</text>
    </view>
  </view>

  <!-- 最新公告 -->
  <view class="section" wx:if="{{announcements.length > 0}}">
    <view class="section-header">
      <text class="section-title">📢 最新公告</text>
      <text class="section-more" bindtap="goAnnouncements">查看更多 ></text>
    </view>
    <view class="card">
      <view class="ann-item" wx:for="{{announcements}}" wx:key="id" bindtap="goAnnouncements">
        <text class="ann-tag">{{item.target==='all'?'全部':'学生专属'}}</text>
        <text class="ann-title">{{item.title}}</text>
      </view>
    </view>
  </view>

  <!-- 进行中订单 -->
  <view class="section" wx:if="{{recentOrders.length > 0}}">
    <view class="section-header">
      <text class="section-title">📋 最近订单</text>
      <text class="section-more" bindtap="goOrders">查看全部 ></text>
    </view>
    <view class="order-card card" wx:for="{{recentOrders}}" wx:key="id">
      <view class="order-top">
        <text class="order-type">{{item.serviceType}}</text>
        <text class="order-status status-{{item.status}}">{{['待接单','待取件','配送中','已送达','已完成','已取消'][item.status]}}</text>
      </view>
      <text class="order-addr">📍 {{item.pickupAddress}} → {{item.deliveryAddress}}</text>
      <view class="order-bottom">
        <text class="order-reward">¥{{item.reward}}</text>
        <text class="order-time">{{item.createTime}}</text>
      </view>
    </view>
  </view>

  <!-- 发单按钮：用 view+flex 居中，比 button 更可靠 -->
  <view class="publish-btn-wrap">
    <view class="publish-btn" bindtap="goPublish" hover-class="publish-btn-hover">
      <text class="publish-btn-text">+ 发布跑腿订单</text>
    </view>
  </view>
</view>
