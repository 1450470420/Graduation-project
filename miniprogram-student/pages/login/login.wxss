.login-page { min-height: 100vh; background: linear-gradient(160deg, #B71C1C 0%, #D32F2F 40%, #f5f5f5 100%); display: flex; flex-direction: column; align-items: center; padding-top: 120rpx; }
.login-header { text-align: center; color: #fff; margin-bottom: 60rpx; }
.logo { font-size: 100rpx; display: block; }
.title { font-size: 52rpx; font-weight: 700; display: block; margin-top: 16rpx; }
.subtitle { font-size: 26rpx; opacity: 0.85; display: block; margin-top: 8rpx; }
.login-form { width: 680rpx; }
.form-item { margin-bottom: 32rpx; }
.label { display: block; font-size: 26rpx; color: #666; margin-bottom: 12rpx; }
.input { border: 2rpx solid #eee; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 30rpx; background: #fafafa; }
.btn-primary {
  margin-top: 16rpx;
  width: 100%;
  background: #D32F2F;
  color: #fff;
  border-radius: 50rpx;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  letter-spacing: 4rpx;
  text-align: center;
  border: none;
  box-sizing: border-box;
  padding: 0;
}
/* 小程序 <button> 自带 ::after 伪元素边框，必须单独清除 */
.btn-primary::after {
  border: none;
}
.go-register { text-align: center; margin-top: 24rpx; color: #999; font-size: 26rpx; }
.link { color: #D32F2F; font-weight: 600; }
