.container{padding:20rpx}
.card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:20rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06)}
.form-title{font-size:28rpx;font-weight:600;color:#333;margin-bottom:12rpx}
.picker-val{font-size:30rpx;color:#D32F2F;font-weight:600;padding:12rpx 0}
.divider{height:1rpx;background:#f0f0f0;margin:20rpx 0}
.textarea{border:2rpx solid #eee;border-radius:8rpx;padding:16rpx;font-size:28rpx;min-height:80rpx;width:100%;box-sizing:border-box}
.input{border:2rpx solid #eee;border-radius:8rpx;padding:16rpx;font-size:28rpx}
.addr-shortcuts{margin-bottom:12rpx}
.addr-tip{font-size:24rpx;color:#999;margin-bottom:8rpx;display:block}
.addr-scroll{white-space:nowrap;display:flex}
.addr-chip{display:inline-block;background:#FFEBEE;color:#D32F2F;font-size:22rpx;padding:8rpx 20rpx;border-radius:30rpx;margin-right:12rpx;white-space:nowrap}
.addr-chip-delivery{background:#FFF8E1;color:#FF8F00}
/* 地址行标题 */
.addr-row-title{display:flex;justify-content:space-between;align-items:center;margin-bottom:10rpx}
.map-btn{background:#E8F5E9;color:#2E7D32;font-size:24rpx;padding:8rpx 20rpx;border-radius:30rpx;text-align:center;}
/* 地图预览 */
.map-preview-section{margin-top:20rpx;padding-top:20rpx;border-top:1rpx solid #f0f0f0}
.map-preview-title{font-size:26rpx;color:#666;margin-bottom:12rpx}
.map-preview{width:100%;height:300rpx;border-radius:12rpx}
.submit-btn{background:#D32F2F;color:#fff;margin:30rpx 20rpx;border-radius:50rpx;height:90rpx;line-height:90rpx;font-size:30rpx;letter-spacing:2rpx;text-align:center;}
