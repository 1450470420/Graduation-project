.page { background: #f5f5f5; min-height: 100vh; }
.balance-card { background: linear-gradient(135deg, #D32F2F, #B71C1C); margin: 24rpx; border-radius: 20rpx; padding: 48rpx 36rpx; color: #fff; text-align: center; }
.balance-label { font-size: 28rpx; opacity: 0.85; display: block; margin-bottom: 16rpx; }
.balance-amount { font-size: 80rpx; font-weight: 700; display: block; margin-bottom: 16rpx; }
.balance-tip { font-size: 22rpx; opacity: 0.7; }
.section-title { font-size: 28rpx; font-weight: 600; color: #333; padding: 20rpx 32rpx 12rpx; }
.loading, .empty { text-align: center; padding: 80rpx 0; color: #999; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.empty-icon { font-size: 60rpx; }
.record-item { background: #fff; margin: 0 24rpx 16rpx; border-radius: 12rpx; padding: 28rpx 32rpx; display: flex; justify-content: space-between; align-items: center; }
.record-left { flex: 1; }
.record-remark { font-size: 28rpx; color: #333; display: block; margin-bottom: 8rpx; }
.record-time { font-size: 24rpx; color: #999; }
.record-amount { font-size: 32rpx; font-weight: 700; }
.income { color: #27AE60; }
.expense { color: #E74C3C; }
