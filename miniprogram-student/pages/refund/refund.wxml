<view class="container">
  <view class="card">
    <view class="title">申请退款</view>
    <!-- 订单信息确认，防止选错订单 -->
    <view class="order-info" wx:if="{{orderNo}}" style="background:#FFF8E1;padding:12rpx 16rpx;border-radius:8rpx;margin-bottom:16rpx;font-size:24rpx;color:#555">
      <text>订单：{{orderNo}}</text><text style="margin-left:20rpx">类型：{{serviceType}}</text>
    </view>
    <view class="tip">⚠️ 退款申请提交后，管理员会在 1-3 个工作日内处理</view>
    <textarea class="textarea" value="{{reason}}" bindinput="onInput" data-field="reason" placeholder="请详细描述退款原因（如：跑腿员未完成服务、物品损坏等）" auto-height/>
    <button class="submit-btn" bindtap="submit" disabled="{{loading}}">{{loading?'提交中...':'提交退款申请'}}</button>
  </view>
</view>
