.container{padding:20rpx}
.card{background:#fff;border-radius:16rpx;padding:32rpx}
.title{font-size:32rpx;font-weight:700;margin-bottom:16rpx}
.tip{background:#FFF8E1;padding:16rpx;border-radius:8rpx;font-size:24rpx;color:#FF9800;margin-bottom:24rpx}
.textarea{border:2rpx solid #eee;border-radius:12rpx;padding:20rpx;font-size:28rpx;min-height:200rpx;width:100%;box-sizing:border-box;margin-bottom:24rpx}
.submit-btn{background:#D32F2F;color:#fff;border-radius:50rpx;height:90rpx;line-height:90rpx;font-size:30rpx;text-align:center;}
