<view class="page">

  <!-- 头像区域 -->
  <view class="avatar-section" bindtap="changeAvatar">
    <view class="avatar-wrap">
      <image class="avatar" src="{{avatarSrc}}" mode="aspectFill"/>
      <view class="camera-mask">
        <image class="camera-icon" src="/assets/camera.png" mode="aspectFit"/>
        <text class="camera-text">更换头像</text>
      </view>
    </view>
    <view wx:if="{{uploading}}" class="uploading-tip">上传中...</view>
  </view>

  <!-- 表单 -->
  <view class="form-card">

    <view class="form-item">
      <text class="label">姓　　名</text>
      <input class="input"
        value="{{form.realName}}"
        bindinput="onInput"
        data-field="form.realName"
        placeholder="请输入真实姓名"/>
    </view>

    <view class="divider"/>

    <view class="form-item">
      <text class="label">手　机　号</text>
      <input class="input"
        type="number"
        value="{{form.phone}}"
        bindinput="onInput"
        data-field="form.phone"
        placeholder="请输入手机号"/>
    </view>

    <view class="divider"/>

    <view class="form-item">
      <text class="label">学　　号</text>
      <input class="input"
        value="{{form.studentId}}"
        bindinput="onInput"
        data-field="form.studentId"
        placeholder="请输入学号"/>
    </view>

    <view class="divider"/>

    <view class="form-item">
      <text class="label">宿舍地址</text>
      <input class="input"
        value="{{form.dormAddress}}"
        bindinput="onInput"
        data-field="form.dormAddress"
        placeholder="如：1号楼301室"/>
    </view>

  </view>

  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="saveProfile" disabled="{{loading || uploading}}">
    {{loading ? '保存中...' : '保存资料'}}
  </button>

</view>
