/* 整体背景 */
.page { min-height: 100vh; background: #f5f5f5; }

/* ===== 头像区域 ===== */
.avatar-section {
  background: linear-gradient(135deg, #D32F2F, #EF5350);
  padding: 50rpx 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.7);
  display: block;
}

/* 底部相机遮罩 */
.camera-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 54rpx;
  background: rgba(0,0,0,0.45);
  border-radius: 0 0 80rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.camera-icon { width: 28rpx; height: 28rpx; }
.camera-text { font-size: 18rpx; color: #fff; line-height: 1; }

.uploading-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

/* ===== 表单卡片 ===== */
.form-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 24rpx 24rpx 0;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #555;
  flex-shrink: 0;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #222;
  padding-left: 12rpx;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
}

/* ===== 保存按钮 ===== */
.save-btn {
  margin: 40rpx 24rpx 60rpx;
  background: #D32F2F;
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  letter-spacing: 4rpx;
  text-align: center;
  border: none;
}

.save-btn[disabled] {
  opacity: 0.6;
}
