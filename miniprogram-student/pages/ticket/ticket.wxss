.container{padding:20rpx}
.add-btn{background:#D32F2F;color:#fff;border-radius:50rpx;height:90rpx;line-height:90rpx;font-size:30rpx;margin-bottom:20rpx;text-align:center;}
.card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:16rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06)}
.ticket-header{display:flex;justify-content:space-between;margin-bottom:12rpx}
.ticket-title{font-size:28rpx;font-weight:600;color:#333;flex:1}
.ticket-status{font-size:22rpx;padding:4rpx 16rpx;border-radius:20rpx}
.s0{background:#FFEBEE;color:#D32F2F}.s1{background:#FFF8E1;color:#FF9800}.s2{background:#f5f5f5;color:#999}
.ticket-content{font-size:26rpx;color:#666;margin-bottom:12rpx;display:block}
.ticket-reply{background:#E8F5E9;padding:12rpx;border-radius:8rpx;margin-bottom:12rpx;font-size:24rpx}
.reply-label{color:#4CAF50;font-weight:600}
.ticket-time{font-size:22rpx;color:#999}
.modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:100}
.modal{position:fixed;bottom:0;left:0;right:0;background:#fff;border-radius:24rpx 24rpx 0 0;padding:30rpx;z-index:101}
.modal-title{font-size:32rpx;font-weight:700;text-align:center;margin-bottom:24rpx}
.input{border:2rpx solid #eee;border-radius:8rpx;padding:16rpx;font-size:28rpx;margin-bottom:16rpx}
.textarea{border:2rpx solid #eee;border-radius:8rpx;padding:16rpx;font-size:28rpx;min-height:160rpx;width:100%;box-sizing:border-box;margin-bottom:20rpx}
.modal-btns{display:flex;gap:20rpx}
.btn-cancel{flex:1;border:2rpx solid #ddd;border-radius:50rpx;height:80rpx;line-height:80rpx;color:#666;text-align:center;}
.btn-confirm{flex:1;background:#D32F2F;color:#fff;border-radius:50rpx;height:80rpx;line-height:80rpx;text-align:center;}
