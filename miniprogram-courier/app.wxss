page{--primary:#2E7D32;--primary-light:#43A047;--primary-dark:#1B5E20;--bg:#f5f5f5;background-color:var(--bg);font-family:-apple-system,"PingFang SC",sans-serif;font-size:28rpx}
.card{background:#fff;border-radius:16rpx;margin:20rpx;padding:24rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06)}
.btn-primary{background:var(--primary);color:#fff;border:none;border-radius:50rpx;font-size:30rpx;height:88rpx;line-height:88rpx;text-align:center;box-sizing:border-box}
/* 全局清除 button::after 默认边框 + 文字居中 */
button::after{border:none}
button{text-align:center}
.tag{display:inline-block;padding:4rpx 16rpx;border-radius:30rpx;font-size:22rpx}
