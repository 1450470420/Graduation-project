.login-page{min-height:100vh;background:linear-gradient(160deg,#1B5E20 0%,#2E7D32 40%,#f5f5f5 100%);display:flex;flex-direction:column;align-items:center;padding-top:100rpx}
.header{text-align:center;color:#fff;margin-bottom:50rpx}.logo{font-size:90rpx;display:block}.title{font-size:48rpx;font-weight:700;display:block;margin-top:12rpx}.sub{font-size:24rpx;opacity:.85;display:block;margin-top:8rpx}
.card{width:680rpx;background:#fff;border-radius:24rpx;padding:40rpx}
.fi{margin-bottom:28rpx;font-size:26rpx;color:#666}.fi input{border:2rpx solid #eee;border-radius:8rpx;padding:16rpx;font-size:28rpx;margin-top:10rpx}
.btn{background:#2E7D32;color:#fff;border-radius:50rpx;height:90rpx;line-height:90rpx;font-size:30rpx;margin-top:12rpx;letter-spacing:2rpx;width:100%;border:none;box-sizing:border-box;text-align:center;padding:0}
.btn::after{border:none}
.reg{text-align:center;margin-top:20rpx;color:#2E7D32;font-size:26rpx}
