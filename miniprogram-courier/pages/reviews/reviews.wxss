.page{background:#f5f5f5;min-height:100vh;padding:20rpx}
.card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:16rpx}
.review-card{}
.reviewer-row{display:flex;align-items:center;gap:16rpx;margin-bottom:20rpx}
.s-avatar{width:72rpx;height:72rpx;border-radius:50%;flex-shrink:0}
.avatar-ph{display:flex;align-items:center;justify-content:center;background:#e8e8e8;font-size:32rpx}
.s-info{flex:1}
.s-name{display:block;font-size:28rpx;font-weight:600;color:#333}
.s-date{display:block;font-size:22rpx;color:#999;margin-top:4rpx}
.stars{font-size:32rpx;color:#FF9800;flex-shrink:0}
.content{font-size:26rpx;color:#555;line-height:1.6;padding-top:16rpx;border-top:1rpx solid #f5f5f5}
.no-content{color:#bbb}
.empty{text-align:center;padding:100rpx;color:#999}
.empty-state{display:flex;flex-direction:column;align-items:center;padding:120rpx 40rpx}
.empty-icon{font-size:100rpx;margin-bottom:24rpx}
.empty-text{font-size:30rpx;color:#666;font-weight:600}
.empty-sub{font-size:24rpx;color:#bbb;margin-top:12rpx}
