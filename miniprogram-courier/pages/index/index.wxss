.courier-status{background:linear-gradient(135deg,#2E7D32,#43A047);padding:30rpx;display:flex;align-items:center;justify-content:space-between;color:#fff}
.avatar-ph{display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.3);font-size:40rpx;flex-shrink:0}
.status-left{display:flex;align-items:center;gap:20rpx}
.avatar{width:80rpx;height:80rpx;border-radius:50%;border:4rpx solid rgba(255,255,255,.5)}
.name{font-size:32rpx;font-weight:700;display:block}.badge-ok{font-size:22rpx}.badge-warn{font-size:22rpx;color:#FFD54F}
.apply-btn{background:#fff;color:#2E7D32;border-radius:30rpx;font-size:24rpx;padding:0 20rpx;height:60rpx;line-height:60rpx}
.filter-bar{display:flex;align-items:center;gap:16rpx;padding:16rpx 20rpx;background:#fff;border-bottom:1rpx solid #f0f0f0}
.filter-btn{background:#E8F5E9;color:#2E7D32;padding:8rpx 20rpx;border-radius:30rpx;font-size:24rpx}
.order-count{color:#666;font-size:24rpx;flex:1}
.refresh{color:#2E7D32;font-size:24rpx}
.order-card{margin:20rpx}
.order-head{display:flex;justify-content:space-between;margin-bottom:16rpx}
.stype{background:#E8F5E9;color:#2E7D32;font-size:22rpx;padding:4rpx 16rpx;border-radius:20rpx}
.reward{color:#E53935;font-size:40rpx;font-weight:700}
.addr-row,.item-row{display:flex;gap:12rpx;margin-bottom:10rpx;font-size:26rpx}
.label{color:#999;white-space:nowrap}.val{color:#333;flex:1}
.student-row{display:flex;justify-content:space-between;margin-top:16rpx;padding-top:16rpx;border-top:1rpx solid #f5f5f5}
.student-name{font-size:24rpx;color:#666}.time{font-size:22rpx;color:#999}
.grab-btn{background:#2E7D32;color:#fff;border-radius:50rpx;height:80rpx;line-height:80rpx;font-size:28rpx;margin-top:16rpx;text-align:center;padding:0}
.no-auth{text-align:center;color:#999;font-size:24rpx;padding:16rpx;background:#f9f9f9;border-radius:8rpx;margin-top:16rpx}
/* 待审核标识文字 */
.pending-tip{color:#FF9800;font-size:22rpx;background:rgba(255,255,255,.2);padding:4rpx 16rpx;border-radius:20rpx}
.loading,.empty{text-align:center;padding:100rpx;color:#999}
/* 空状态相关样式 */
.empty-state{display:flex;flex-direction:column;align-items:center;padding:80rpx 40rpx;color:#999}
.empty-icon{font-size:100rpx;margin-bottom:20rpx}
.empty-sub{font-size:24rpx;color:#bbb;margin-top:12rpx;margin-bottom:30rpx}
.refresh-btn{background:#2E7D32;color:#fff;border-radius:50rpx;font-size:26rpx;padding:0;height:80rpx;line-height:80rpx;text-align:center}
