<view class="page">

  <!-- 头像区域 -->
  <view class="avatar-section" bindtap="changeAvatar">
    <view class="avatar-wrap">
      <image wx:if="{{form.avatarUrl}}" class="avatar" src="{{form.avatarUrl}}" mode="aspectFill"/>
      <view wx:else class="avatar avatar-ph">👤</view>
      <view class="avatar-mask">
        <text class="camera-icon">📷</text>
      </view>
    </view>
    <text class="avatar-tip" wx:if="{{!uploading}}">点击更换头像</text>
    <text class="uploading-tip" wx:if="{{uploading}}">上传中...</text>
  </view>

  <!-- 表单 -->
  <view class="form-card">
    <view class="form-item">
      <text class="label">姓名</text>
      <input class="input" value="{{form.realName}}" bindinput="onInput" data-field="form.realName" placeholder="请输入真实姓名" placeholder-class="ph"/>
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" value="{{form.phone}}" bindinput="onInput" data-field="form.phone" placeholder="请输入手机号" placeholder-class="ph"/>
    </view>
    <view class="form-item last">
      <text class="label">宿舍地址</text>
      <input class="input" value="{{form.dormAddress}}" bindinput="onInput" data-field="form.dormAddress" placeholder="请输入宿舍地址" placeholder-class="ph"/>
    </view>
  </view>

  <button class="save-btn" bindtap="save" disabled="{{saving||uploading}}">{{saving?'保存中...':'保存'}}</button>

</view>
