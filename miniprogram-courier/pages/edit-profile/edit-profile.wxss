.page{background:#f5f5f5;min-height:100vh;padding-bottom:60rpx}

.avatar-section{display:flex;flex-direction:column;align-items:center;padding:60rpx 0 40rpx;background:#fff;margin-bottom:24rpx}
.avatar-wrap{position:relative;width:160rpx;height:160rpx;border-radius:50%;overflow:hidden;border:4rpx solid #e0e0e0}
.avatar{width:160rpx;height:160rpx;display:block}
.avatar-ph{display:flex;align-items:center;justify-content:center;background:#e0e0e0;font-size:70rpx;width:160rpx;height:160rpx}
.avatar-mask{position:absolute;bottom:0;left:0;right:0;height:52rpx;background:rgba(0,0,0,.45);display:flex;align-items:center;justify-content:center}
.camera-icon{font-size:28rpx}
.avatar-tip{font-size:24rpx;color:#999;margin-top:16rpx}
.uploading-tip{font-size:24rpx;color:#2E7D32;margin-top:16rpx}

.form-card{background:#fff;margin:0 24rpx;border-radius:16rpx;overflow:hidden}
.form-item{display:flex;align-items:center;padding:28rpx 24rpx;border-bottom:1rpx solid #f5f5f5}
.form-item.last{border-bottom:none}
.label{width:140rpx;font-size:28rpx;color:#333;flex-shrink:0}
.input{flex:1;font-size:28rpx;color:#333}
.ph{color:#bbb}

.save-btn{margin:40rpx 24rpx 0;background:#2E7D32;color:#fff;border-radius:50rpx;height:90rpx;line-height:90rpx;font-size:32rpx;text-align:center;padding:0;border:none;box-sizing:border-box}
.save-btn::after{border:none}
.save-btn[disabled]{background:#a5d6a7;color:#fff}
