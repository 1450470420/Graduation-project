.container{padding:20rpx}.card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:20rpx}
.status-top{border-radius:20rpx;padding:30rpx;margin-bottom:20rpx;display:flex;align-items:center;gap:20rpx;color:#fff}
.s1,.s2{background:linear-gradient(135deg,#FF9800,#FFB74D)}.s3,.s4{background:linear-gradient(135deg,#2E7D32,#43A047)}.s5{background:linear-gradient(135deg,#9E9E9E,#BDBDBD)}
.si{font-size:60rpx}.st{font-size:32rpx;font-weight:700;display:block}.sn{font-size:22rpx;opacity:.85}.rw{margin-left:auto;font-size:42rpx;font-weight:700}
.row{display:flex;gap:12rpx;margin-bottom:16rpx;font-size:26rpx}.l{color:#999;white-space:nowrap}.v{flex:1;color:#333}
.actions{display:flex;flex-direction:column;gap:16rpx}
.btn-green{background:#2E7D32;color:#fff;border-radius:50rpx;height:90rpx;line-height:90rpx;font-size:28rpx;text-align:center;padding:0}
.btn-chat{background:#fff;color:#2E7D32;border:2rpx solid #2E7D32;border-radius:50rpx;height:80rpx;line-height:80rpx;font-size:28rpx;text-align:center;padding:0}
/* 地图相关 */
.map-title{display:block;font-size:28rpx;font-weight:600;color:#333;margin-bottom:16rpx}
.order-map{width:100%;height:360rpx;border-radius:12rpx}
.nav-btns{display:flex;gap:16rpx;margin-top:16rpx}
.nav-btn{flex:1;border-radius:50rpx;height:80rpx;line-height:80rpx;font-size:26rpx;text-align:center;padding:0}
.nav-btn.pickup{background:#D32F2F;color:#fff}
.nav-btn.delivery{background:#2E7D32;color:#fff}
.map-hint{font-size:24rpx;color:#999;display:block;margin-top:12rpx;text-align:center}
.face-status-card{border:2rpx solid #E3F2FD;background:#F8FBFF}
.face-row{display:flex;align-items:center;gap:16rpx;margin-bottom:12rpx}
.face-label{font-size:28rpx;font-weight:600;color:#333;flex:1}
.face-badge{font-size:22rpx;padding:6rpx 16rpx;border-radius:20rpx}
.f-pass{background:#E8F5E9;color:#2E7D32}
.f-wait{background:#FFF3E0;color:#E65100}
.face-tip{font-size:24rpx;color:#666;display:block;line-height:1.6}
