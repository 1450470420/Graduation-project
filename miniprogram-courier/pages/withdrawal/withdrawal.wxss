.container{padding:20rpx}
/* 页头余额提示卡 */
.balance-tip-card{background:linear-gradient(135deg,#2E7D32,#43A047);margin:0 0 16rpx;padding:40rpx 30rpx;text-align:center;color:#fff}
.btl{display:block;font-size:26rpx;opacity:.85;margin-bottom:10rpx}
.bta{display:block;font-size:72rpx;font-weight:700}
.card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:16rpx}
.form-title{font-size:30rpx;font-weight:700;margin-bottom:24rpx}
.fi{margin-bottom:20rpx;font-size:26rpx;color:#666}.fi input,.picker{border:2rpx solid #eee;border-radius:8rpx;padding:14rpx;font-size:28rpx;margin-top:8rpx;color:#333}
.picker{color:#2E7D32}
.btn{background:#2E7D32;color:#fff;border-radius:50rpx;height:90rpx;line-height:90rpx;font-size:30rpx;margin-top:12rpx;text-align:center;padding:0}
.section-title{font-size:28rpx;font-weight:700;padding:0 0 10rpx;color:#333}
.record{padding:20rpx}.rh{display:flex;justify-content:space-between;margin-bottom:8rpx}
.rm{background:#E8F5E9;color:#2E7D32;font-size:22rpx;padding:4rpx 16rpx;border-radius:20rpx}
.status{font-size:22rpx}.s0{color:#FF9800}.s1{color:#2E7D32}.s2{color:#F44336}
.ra{display:block;font-size:36rpx;font-weight:700;color:#E53935;margin-bottom:6rpx}
.rac,.rt,.rr{display:block;font-size:24rpx;color:#999;margin-bottom:4rpx}
.rr{color:#FF9800}
