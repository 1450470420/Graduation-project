.page{min-height:100vh;background:linear-gradient(160deg,#1B5E20 0%,#2E7D32 40%,#f5f5f5 100%);display:flex;flex-direction:column;align-items:center;padding-top:80rpx}
.header{text-align:center;color:#fff;margin-bottom:40rpx}.logo{font-size:70rpx;display:block}.title{font-size:40rpx;font-weight:700;display:block;margin-top:10rpx}
.card{width:680rpx;background:#fff;border-radius:24rpx;padding:40rpx}
.fi{margin-bottom:24rpx;font-size:26rpx;color:#666}.fi input{border:2rpx solid #eee;border-radius:8rpx;padding:16rpx;font-size:28rpx;margin-top:8rpx}
.btn{background:#2E7D32;color:#fff;border-radius:50rpx;height:90rpx;line-height:90rpx;font-size:30rpx;margin-top:12rpx;text-align:center;padding:0}
.back{text-align:center;color:#2E7D32;font-size:26rpx;margin-top:20rpx}
