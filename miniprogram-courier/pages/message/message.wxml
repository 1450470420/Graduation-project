<view class="page">
  <view class="msg-item" wx:for="{{messages}}" wx:key="id" class="msg-item {{item.isRead?'':'unread'}}">
    <text class="icon">{{item.type==='order'?'📦':'🔔'}}</text>
    <view class="content"><text class="title">{{item.title}}</text><text class="body">{{item.content}}</text><text class="time">{{item.createTime}}</text></view>
  </view>
  <view wx:if="{{messages.length===0}}" style="text-align:center;padding:100rpx;color:#999">暂无消息</view>
</view>
