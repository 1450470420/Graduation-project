.msg-item{display:flex;gap:16rpx;padding:24rpx;background:#fff;border-bottom:1rpx solid #f5f5f5}
.msg-item.unread{background:#F1F8E9}.icon{font-size:48rpx;flex-shrink:0}
.title{display:block;font-size:28rpx;font-weight:600;margin-bottom:6rpx}
.body{display:block;font-size:24rpx;color:#666;margin-bottom:6rpx}
.time{display:block;font-size:22rpx;color:#999}
