<view class="page">
  <view class="tabs">
    <view wx:for="{{tabs}}" wx:key="index" class="tab {{activeTab===index?'active':''}}" bindtap="changeTab" data-index="{{index}}">{{item}}</view>
  </view>
  <!-- loading 优先，防止加载期间错误显示“暂无订单” -->
  <view wx:if="{{loading}}" style="text-align:center;padding:80rpx;color:#999">加载中...</view>
  <view wx:elif="{{orders.length===0}}" class="empty" style="text-align:center;padding:100rpx;color:#999">暂无订单</view>
  <view class="order-card card" wx:for="{{orders}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
    <view class="oh"><text class="stype">{{item.serviceType}}</text><text class="reward">¥{{item.reward}}</text></view>
    <view class="row"><text class="l">取件</text><text class="v">{{item.pickupAddress}}</text></view>
    <view class="row"><text class="l">送至</text><text class="v">{{item.deliveryAddress}}</text></view>
    <view class="row"><text class="l">学生</text><text class="v">{{item.studentName}} {{item.studentPhone}}</text></view>
    <view class="status-row"><text class="s{{item.status}}">{{['待接单','待取件','配送中','已送达','已完成','已取消'][item.status]}}</text><text class="t">{{item.createTime}}</text></view>
  </view>
</view>
