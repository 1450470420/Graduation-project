.chat-page{display:flex;flex-direction:column;height:100vh}
.poll-indicator{display:flex;align-items:center;justify-content:center;gap:8rpx;padding:8rpx 0;background:#E8F5E9}
.poll-dot{width:12rpx;height:12rpx;border-radius:50%;background:#4CAF50;animation:blink 1.5s infinite}
.poll-text{font-size:22rpx;color:#2E7D32}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.msg-list{flex:1;padding:20rpx;background:#f5f5f5}
.msg-row{display:flex;flex-direction:column;margin-bottom:20rpx}
.msg-row.self{align-items:flex-end}.msg-row.other{align-items:flex-start}
.bubble{background:#fff;padding:16rpx 24rpx;border-radius:18rpx;max-width:500rpx;font-size:28rpx}
.msg-row.self .bubble{background:#2E7D32;color:#fff}
.input-bar{display:flex;gap:16rpx;padding:16rpx;background:#fff;border-top:1rpx solid #f0f0f0}
.input,.chat-input{flex:1;border:2rpx solid #eee;border-radius:50rpx;padding:0 24rpx;height:72rpx;line-height:72rpx;font-size:28rpx}
.send,.send-btn{background:#2E7D32;color:#fff;border-radius:50rpx;font-size:26rpx;padding:0 32rpx;height:72rpx;line-height:72rpx}
