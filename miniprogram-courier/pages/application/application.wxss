.container{padding:20rpx}.card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:16rpx}
.status-card{text-align:center}.sh{font-size:26rpx;color:#666;margin-bottom:16rpx}
.status{font-size:40rpx;font-weight:700;margin-bottom:12rpx}
.s0{color:#FF9800}.s1{color:#2E7D32}.s2{color:#F44336}
.reason{display:block;font-size:24rpx;color:#F44336;margin-top:10rpx}
.ok-tip{display:block;font-size:26rpx;color:#2E7D32;margin-top:16rpx;background:#E8F5E9;padding:16rpx;border-radius:8rpx}
.form-title{font-size:30rpx;font-weight:700;margin-bottom:24rpx}
.fi{margin-bottom:20rpx;font-size:26rpx;color:#666}.fi input,.ta{border:2rpx solid #eee;border-radius:8rpx;padding:14rpx;font-size:28rpx;margin-top:8rpx}
.ta{min-height:100rpx;width:100%;box-sizing:border-box}
.btn{background:#2E7D32;color:#fff;border-radius:50rpx;height:90rpx;line-height:90rpx;font-size:30rpx;margin-top:12rpx;text-align:center;padding:0}
/* 审核通过后引导接单按鈕 */
.start-btn{background:#2E7D32;color:#fff;border-radius:50rpx;height:90rpx;line-height:90rpx;font-size:30rpx;margin-top:24rpx;letter-spacing:2rpx;text-align:center;padding:0}
