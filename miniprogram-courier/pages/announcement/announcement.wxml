<view class="container">
  <view class="card" wx:for="{{items}}" wx:key="id"><text class="title">{{item.title}}</text><text class="content">{{item.content}}</text><text class="time">{{item.createTime}}</text></view>
  <view wx:if="{{items.length===0}}" style="text-align:center;padding:100rpx;color:#999">暂无公告</view>
</view>
